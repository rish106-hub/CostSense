# ============================================================
# CostSense AI — Environment Variables
# Copy this file to .env and replace placeholder values.
# ============================================================

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://costsense_user:your_password_here@localhost:5432/costsense_db

# --- LLM via OpenRouter (free tier — get key at openrouter.ai) ---
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free-tier model fallback chain (primary → fallback_1 → fallback_2)
LLM_MODEL_PRIMARY=meta-llama/llama-3.1-8b-instruct:free
LLM_MODEL_FALLBACK_1=mistralai/mistral-7b-instruct:free
LLM_MODEL_FALLBACK_2=google/gemma-2-9b-it:free

# LLM generation settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=256
LLM_TIMEOUT_SECONDS=30

# --- Embeddings (OpenAI or compatible endpoint) ---
OPENAI_API_KEY=sk-your-openai-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Event Bus ---
# "memory" uses asyncio.Queue (zero infra, default)
# "redis" swaps to Redis Streams (requires REDIS_URL below)
EVENT_BUS_BACKEND=memory
EVENT_BUS_HISTORY_SIZE=2000

# --- Redis (only needed if EVENT_BUS_BACKEND=redis) ---
# REDIS_URL=redis://localhost:6379/0

# --- Scoring Thresholds ---
APS_APPROVAL_THRESHOLD=4.0
COMPLEXITY_APPROVAL_THRESHOLD=2

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Streamlit UI ---
# Base URL of the running FastAPI server
API_BASE_URL=http://localhost:8000

# --- Synthetic Data Generator ---
SYNTHETIC_RECORD_COUNT=86
SYNTHETIC_SEED=42
